<form asp-controller="Reports" asp-action="GenerateReport" method="post" class="d-inline">
    <input type="hidden" name="DiagnosisId" value="@Model" />
    <input type="hidden" name="Format" value="PDF" />
    <button type="submit" class="btn btn-sm btn-outline-success mb-1">
        <i class="fas fa-file-pdf"></i>
    </button>
</form>

