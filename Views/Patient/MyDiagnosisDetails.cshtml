@model MediAI.Models.Diagnosis
@inject IStringLocalizer<MediAI.Resources.Diagnoses.Resources> Localizer

@{
    ViewData["Title"] = Localizer["Diagnosis_Details"];
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow mb-4">
                <div class="card-header text-center">
                    <h2>@Localizer["Diagnosis_Details"]</h2>
                </div>
                <div class="card-body">

                    <div class="mb-3">
                        <label class="form-label">@Localizer["RequestDescription"]</label>
                        <input class="form-control" value="@Model.RequestDescription" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">@Localizer["Priority"]</label>
                        <input class="form-control" value="@Model.Priority.ToString()" readonly />
                    </div>

                    <div class="mb-3">
                        <label class="form-label">@Localizer["Symptoms"]</label>
                        <div class="form-control" style="height:auto;" readonly>
                            @if (Model.DiagnosisSymptoms != null && Model.DiagnosisSymptoms.Any())
                            {
                                <ul>
                                    @foreach (var symptom in Model.DiagnosisSymptoms)
                                    {
                                        <li>@symptom.Symptom?.Name</li>
                                    }
                                </ul>
                            }
                            else
                            {
                                <span class="text-muted">@Localizer["NoSymptoms"]</span>
                            }
                        </div>
                    </div>

                    <div class="mb-4">
                        <label class="form-label">@Localizer["UploadedImage"]</label>
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="image-preview">
                                <img src="@Model.ImageUrl" alt="Scan" class="img-fluid" style="max-height:300px;" />
                            </div>
                        }
                        else
                        {
                            <div class="text-muted">@Localizer["NoImageUploaded"]</div>
                        }
                    </div>

                    <div class="mb-4">
                        <label class="form-label">@Localizer["ConfidenceLevel"]</label>
                        @*@if (Model.ConfidenceLevel != null)
            {
                var percentage = Math.Round(Model.ConfidenceLevel.Value * 100, 2);
                <div class="progress" style="height: 20px; direction: ltr;">
                    <div class="progress-bar bg-info text-start ps-2" role="progressbar"
                         style="width: @percentage%;" aria-valuenow="@percentage"
                         aria-valuemin="0" aria-valuemax="100">
                        @percentage%
                    </div>
                </div>
            }
            else
            {
                <p class="text-muted">@Localizer["NoConfidenceAvailable"]</p>
            }*@

                        @if (Model.ConfidenceLevel != null)
                        {
                            var confidence = Model.ConfidenceLevel.HasValue
                            ? Math.Round(Model.ConfidenceLevel.Value * 100, 2)
                            : 0;

                            <label class="form-label">نسبة الثقة من الذكاء الاصطناعي:</label>
                            <div class="progress" style="height: 20px;">
                                <div class="progress-bar bg-info text-start ps-2" role="progressbar"
                                     style="width:@confidence.ToString(System.Globalization.CultureInfo.InvariantCulture)%"
                                     aria-valuenow="@confidence"
                                     aria-valuemin="0" aria-valuemax="100">
                                </div>
                            </div>
                            <small class="text-muted">@confidence%</small>
                        }
                    </div>

                    <div class="mb-4">
                        <label class="form-label">@Localizer["DiagnosisResult"]</label>
                        <input class="form-control" value="@Model.Condition" readonly />
                    </div>

                    <div class="mb-4">
                        <label class="form-label">@Localizer["Status"]</label>
                        <input class="form-control" value="@Model.Status.ToString()" readonly />
                    </div>

                    @if (Model.Status == DiagnosisStatus.Completed && !string.IsNullOrWhiteSpace(Model.DoctorId))
                    {
                        @await Html.PartialAsync("_DownloadReportPartial", Model.Id)
                    }
                    <div class="text-center mt-3">
                        <a asp-action="PatientDashboard" class="btn btn-outline-primary">@Localizer["Dashboard"]</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>